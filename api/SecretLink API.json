    {
      "name": "MFA",
      "item": [
        {
          "name": "Generate MFA secret",
          "event": [],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "disabled": false,
                "type": "default"
              }
            ],
            "auth": {
              "type": "noauth"
            },
            "description": "Générer un secret TOTP avant l'inscription. Vérifie la disponibilité de l'email.",
            "url": {
              "raw": "{{base_url}}/users/mfa/generate",
              "protocol": "",
              "host": [
                "{{base_url}}"
