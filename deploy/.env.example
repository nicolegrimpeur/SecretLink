# ==========================================
# Database Configuration
# ==========================================
MYSQL_USER=root
MYSQL_PASSWORD=root

# ==========================================
# Server Configuration
# ==========================================
NODE_ENV=production
PORT=3000
BASE_URL=http://localhost:3000

# Database connection (from container to container)
MYSQL_HOST=secretlink-db
MYSQL_PORT=3306

# ==========================================
# Security Keys
# ==========================================
# Master encryption key for secrets
MASTER_KEY_V1=your-secret-key-here

# Key version for managing key rotations
KEY_VERSION=1

# Session secret for session management
SESSION_SECRET=your-session-secret-here

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=info
